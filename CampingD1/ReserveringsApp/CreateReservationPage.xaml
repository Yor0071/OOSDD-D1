<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ReserveringsApp.CreateReservationPage"
             Title="Maak een reservering"
             BackgroundColor="White">
    <VerticalStackLayout VerticalOptions="CenterAndExpand" HorizontalOptions="CenterAndExpand">
        <Label Text="Welkom bij de reserveringspagina!" 
               FontSize="Large" 
               FontAttributes="Bold" 
               HorizontalOptions="Center" />
        <Button Text="Terug naar hoofdscherm" 
                Clicked="OnBackButtonClicked" 
                HorizontalOptions="Center" />
    </VerticalStackLayout>
</ContentPage>
